<svg xmlns="http://www.w3.org/2000/svg" width="340" height="64" viewBox="0 0 340 64"
     role="img" aria-label="EARLY EAGLE #0 — Frosty Narwhal">
  <title>EARLY EAGLE #0 — Frosty Narwhal · Legendary</title>
  <defs>
    <linearGradient id="ee0bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#0d1525"/>
      <stop offset="100%" stop-color="#08101e"/>
    </linearGradient>
    <linearGradient id="ee0bar" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#d4a84b"/>
      <stop offset="100%" stop-color="#d4a84b" stop-opacity="0.35"/>
    </linearGradient>
    <clipPath id="ee0cl"><rect width="340" height="64" rx="10"/></clipPath>
  </defs>

  <script type="text/javascript"><![CDATA[
    function ee0cp(id,v){if(!navigator.clipboard)return;navigator.clipboard.writeText(v).then(function(){var e=document.getElementById(id);if(!e)return;e.textContent='✓';setTimeout(function(){e.textContent='';},1600);});}
  ]]></script>

  <g clip-path="url(#ee0cl)">
    <rect width="340" height="64" fill="url(#ee0bg)"/>
    <rect x="0" y="0" width="4" height="64" fill="url(#ee0bar)"/>
    <rect width="340" height="64" rx="10" fill="none"
          stroke="#d4a84b" stroke-width="0.8" stroke-opacity="0.22"/>

    <!-- Header / address divider -->
    <line x1="4" y1="45" x2="340" y2="45"
          stroke="rgba(255,255,255,0.08)" stroke-width="0.6"/>

    <!-- ── Row A: icon · title LEFT  |  tier pill RIGHT ─────────────── -->

    <rect x="12" y="7" width="18" height="18" rx="4" fill="rgba(212,168,75,0.18)"/>
    <text x="21" y="20" font-size="11" text-anchor="middle"
          font-family="Apple Color Emoji,Segoe UI Emoji,Noto Color Emoji,serif">🦅</text>

    <text x="36" y="21"
          font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
          font-size="11" font-weight="700" fill="#eef3ff" letter-spacing="0.2">EARLY EAGLE #0</text>

    <rect x="260" y="7" width="72" height="16" rx="5"
          fill="rgba(212,168,75,0.18)" stroke="#d4a84b" stroke-width="0.6" stroke-opacity="0.5"/>
    <text x="296" y="18"
          font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
          font-size="7.5" font-weight="800" fill="#e8c26a" text-anchor="middle"
          letter-spacing="1.2">LEGENDARY</text>

    <!-- ── Row B: name (left)  |  ✓ · View Profile → (right cluster) ─── -->

    <text x="36" y="37"
          font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
          font-size="10" font-weight="500" fill="#8ba4c4">Iskander · Frosty Narwhal</text>

    <text x="258" y="37" text-anchor="end"
          font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
          font-size="7.5" fill="#00c97a">✓ on-chain</text>

    <a href="https://early-eagles.vercel.app/eagle/0" target="_blank">
      <text x="332" y="37"
            font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
            font-size="8" fill="#e8c26a" text-anchor="end" opacity="0.9">View Profile →</text>
    </a>

    <!-- ── Single address row: STX left  ·  BTC right ────────────────── -->
    <!-- Addresses abbreviated (abbrev: 8+…+6 chars) at larger 9px font. -->
    <!-- Copy icon = two overlapping squares (clipboard). No text label.  -->

    <text x="51" y="59"
          font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
          font-size="7" font-weight="700" letter-spacing="0.6" fill="#e8c26a">STX</text>
    <text x="69" y="59"
          font-family="'SF Mono','Fira Code','Consolas',monospace"
          font-size="9" fill="#8899b4">SP3JR7JX…N0P12E</text>
    
    <g onclick="ee0cp('ee0sc','SP3JR7JXFT7ZM9JKSQPBQG1HPT0D365MA5TN0P12E')" style="cursor:pointer">
      <rect x="153"   y="54" width="5" height="5" rx="0.8"
            fill="#0d1525" stroke="rgba(255,255,255,0.18)" stroke-width="0.6"/>
      <rect x="155" y="52"   width="5" height="5" rx="0.8"
            fill="#0d1525" stroke="rgba(255,255,255,0.32)" stroke-width="0.6"/>
      <text id="ee0sc" x="157.5" y="57.5"
            font-family="-apple-system,BlinkMacSystemFont,sans-serif"
            font-size="5.5" font-weight="700" fill="#00c97a" text-anchor="middle"></text>
    </g>

    
    <text x="180" y="59"
          font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
          font-size="7" font-weight="700" letter-spacing="0.6" fill="#f7931a">BTC</text>
    <text x="198" y="59"
          font-family="'SF Mono','Fira Code','Consolas',monospace"
          font-size="9" fill="#8899b4">bc1qukpu…ckql4d</text>
    
    <g onclick="ee0cp('ee0bc','bc1qukpuht73lazv57dajauqvdksrge3dz3wckql4d')" style="cursor:pointer">
      <rect x="282"   y="54" width="5" height="5" rx="0.8"
            fill="#0d1525" stroke="rgba(255,255,255,0.18)" stroke-width="0.6"/>
      <rect x="284" y="52"   width="5" height="5" rx="0.8"
            fill="#0d1525" stroke="rgba(255,255,255,0.32)" stroke-width="0.6"/>
      <text id="ee0bc" x="286.5" y="57.5"
            font-family="-apple-system,BlinkMacSystemFont,sans-serif"
            font-size="5.5" font-weight="700" fill="#00c97a" text-anchor="middle"></text>
    </g>
    
  </g>
</svg>