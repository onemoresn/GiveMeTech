# Required for GitHub Actions daily feed updates (Settings → Secrets → Actions).
# Get a free key at https://www.pexels.com/api/
#
# For local runs, copy this file to .env and paste your key:
#   cp .env.example .env
#
# Never commit .env — it is gitignored.
PEXELS_API_KEY=

# Optional: Gemini 1.5 Flash for AI-generated article summaries (free tier at aistudio.google.com)
# Guardrails: key alone does not enable calls — set GEMINI_ENABLED=true explicitly.
GEMINI_API_KEY=
GEMINI_ENABLED=false
# Max Gemini calls per fetch run (default 12 ≈ one short excerpt per section)
GEMINI_MAX_CALLS=12

# Optional: SiteCommand deploy/feed webhook (GitHub Actions secret SITECOMMAND_WEBHOOK_URL)
# SITECOMMAND_WEBHOOK_URL=
